        {
            "type": "shell",
            "label": "C/C++: g++.exe build active file",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "$srcs = Get-ChildItem -Path \"${workspaceFolder}\\srcs\\sources\" -Filter *.cpp | ForEach-Object { $_.FullName }; & \"D:\\mingw64\\bin\\g++.exe\" -fdiagnostics-color=always \"-I${workspaceFolder}\\thirdparty\\easylog\" \"-I${workspaceFolder}\\thirdparty\\easybmp\" \"-I${workspaceFolder}\\thirdparty\\json\\nlohmann\" \"-I${workspaceFolder}\\srcs\\include\" -g \"${workspaceFolder}\\main.cpp\" @($srcs) -o \"${workspaceFolder}\\main.exe\""
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}